<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Team Promptify - Webseite</title>

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            margin: 0;
            font-family: 'Poppins', Arial, sans-serif;
            background: #ffffff;
            color: #222;
        }

        header {
            text-align: center;
            padding: 30px 20px;
            background: linear-gradient(135deg, #000000, #391255);
            color: white;
        }

        header h1 {
            margin-bottom: 10px;
            font-weight: 600;
            letter-spacing: 1px;
        }

        main {
            padding: 20px;
            max-width: 900px;
            margin: auto;
        }

        section {
            background: #ffffff;
            padding: 20px;
            margin-bottom: 20px;
            border-radius: 10px;
            box-shadow: 0 2px 6px rgba(0,0,0,0.08);
            border-left: 4px solid #6a0dad;
        }

        h2 {
            margin-top: 0;
            color: #111;
            font-weight: 600;
        }

        h3 {
            color: #8f5db2;
            font-weight: 500;
        }

        ul {
            list-style: none;
            padding: 0;
        }

        li {
            margin: 8px 0;
            font-weight: 300;
        }

        a {
            color: #6a0dad;
            text-decoration: none;
            font-weight: 500;
            transition: 0.2s;
        }

        a:hover {
            text-decoration: underline;
            opacity: 0.8;
        }

        footer {
            text-align: center;
            padding: 15px;
            background: #f5f5f5;
            margin-top: 30px;
            font-size: 0.9em;
            color: #555;
        }

        img {
            margin-top: 10px;
            border-radius: 8px;
        }
    
        .jour {
            color: #7c3aed; /* softer violet */
            font-weight: 500;
        }

        .review {
            color: #0f766e; /* teal accent for contrast */
            font-weight: 600;
        }

        .main-link {
            margin-bottom: 10px;
        }

        .main-link a {
            font-weight: 600;
        }

        .sub-link {
            font-size: 0.9em;
            opacity: 0.8;
        }

        .sub-link a {
            font-weight: 400;
        }

    </style>
</head>
<body>

<header>
    <h1>Team Promptify</h1>
    <img src="teamlogo.jpg" alt="Logo von Team Promptify" style="width:200px;height:auto;">
    <h3>SEP Sommersemester 2026</h3>
</header>

<main>

    <section>
        <h2>Unsere Teammitglieder</h2>
        <ul>
            <li><strong>✦ Tomas</strong> – Rolle</li>
            <li><strong>✦ Ioana</strong> – Rolle</li>
            <li><strong>✦ Luis</strong> – Rolle</li>
            <li><strong>✦ Tobias</strong> – Rolle</li>
            <li><strong>✦ Adrian</strong> – Rolle</li>
        </ul>
    </section>

    <section>
        <h2>Teamabgaben und Dateien</h2>
        <ul>
            <li class="main-link"><a href="bla.pdf">🗀 Zum gesamten Dateiverzeichnis</a></li>
            <li class="sub-link"><a href="wiki.pdf">☛ Moodle Wiki-Seite</a></li>
            <li class="sub-link"><a href="steckbrief.pdf">☛ Steckbrief</a></li>
        </ul>
    </section>

    <section>
        <h2>Aktuelle Berichte</h2>
        <h3 style="color: #111;">Zeitplan</h3>
        <ul>
            <li class="jour">▶ 15.04.2026 – Jour Fixe</li>
            <li class="jour">▶ 22.04.2026 – Jour Fixe</li>
            <li class="review">▶ 29.04.2026 – Review</li>
            <li class="jour">▶ 06.05.2026 – Jour Fixe</li>
            <li class="review">▶ 13.05.2026 – Review</li>
            <li class="jour">▶ 20.05.2026 – Jour Fixe</li>
            <li class="review">▶ 03.06.2026 – Review</li>
            <li class="jour">▶ 10.06.2026 – Jour Fixe</li>
            <li class="review">▶ 17.06.2026 – Review</li>
            <li class="jour">▶ 24.06.2026 – Jour Fixe</li>
        </ul>
    </section>

</main>

<footer>
    <p>&copy; 2026 Team Promptify – Alle Rechte vorbehalten</p>
</footer>

</body>
</html>
