@startuml System Architecture Component Diagram

' ─── SKINPARAM ───
skinparam componentStyle rectangle
skinparam defaultFontName Arial
skinparam defaultFontSize 13
skinparam roundCorner 12
skinparam shadowing false
skinparam ArrowThickness 1.5

skinparam component {
  BackgroundColor<<db>>       #9FE1CB
  BorderColor<<db>>           #0F6E56
  FontColor<<db>>             #085041

  BackgroundColor<<backend>>  #B5D4F4
  BorderColor<<backend>>      #185FA5
  FontColor<<backend>>        #0C447C

  BackgroundColor<<frontend>> #CECBF6
  BorderColor<<frontend>>     #534AB7
  FontColor<<frontend>>       #3C3489

  BackgroundColor<<suggested>> #FAC775
  BorderColor<<suggested>>     #BA7517
  FontColor<<suggested>>       #633806
}

skinparam database {
  BackgroundColor #9FE1CB
  BorderColor     #0F6E56
  FontColor       #085041
}

skinparam rectangle {
  BackgroundColor<<frontend>> #E8E7FC
  BorderColor<<frontend>>     #534AB7
  FontColor<<frontend>>       #3C3489
}

skinparam note {
  BackgroundColor #FAEEDA
  BorderColor     #BA7517
  FontColor       #633806
}


legend top right
  |= Color |= Layer / Role |
  |<#9FE1CB> Teal   | Data layer (Supabase DB) |
  |<#B5D4F4> Blue   | API layer (FastAPI)       |
  |<#CECBF6> Purple | Frontend layer            |
  |<#FAC775> Amber  | Suggested / theoretical   |
  |  - - ->         | Suggested flow            |
  |  . . .>         | Theoretical flow          |
endlegend


package "Data Layer" {
  database "Supabase DB\n<size:11>PostgreSQL · Auth · Realtime</size>" <<db>> as DB
}


package "API Layer" {
  component "FastAPI Backend\n<size:11>Python · REST / WebSocket</size>" <<backend>> as API
}


package "Frontend Layer" {
  rectangle "Frontend Dashboard" <<frontend_shell>> {
    component "Data Table\n<size:11>Display · Pagination</size>" <<frontend>> as Table
    component "Search & Filter\n<size:11>Query · Sort · Filter</size>" <<frontend>> as SearchFilter
    component "Survey / Preferences\n<size:11>User preferences [suggested]</size>" <<suggested>> as Survey
  }
}


DB          -down-> API          : queries / responses
API         -down-> Table        : data feed
SearchFilter -up->  API          : search & filter requests

' Suggested
Survey      -up[#BA7517,dashed]-> API : may send preferences\n<size:10>[suggested]</size>
API         -up[#BA7517,dashed]-> DB  : write user prefs\n<size:10>[suggested · bijective]</size>
DB          -down[#BA7517,dashed]-> API : return prefs\n<size:10>[suggested · bijective]</size>

' Suggested Flow
Survey      .[#BA7517].>  DB : theoretical direct access\n<size:10>[via backend only]</size>

' Notes
note right of Survey
  <color:#BA7517>Amber = architectural suggestion.
  Direct DB access would route
  bijectively through the backend.
end note

note right of API
  Bidirectional preference sync
  <color:#BA7517>(suggested)</color> allows the backend
  to read and write user prefs
  stored in Supabase.
end note

@enduml